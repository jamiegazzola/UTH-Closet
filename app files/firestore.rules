rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile; admins can read/write all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Orders: students can create, staff/admin can read+update for their school
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (isStaff() || isAdmin());
    }

    // Activity log: staff can create/read for their school, admin can read all
    match /activity_log/{logId} {
      allow create: if request.auth != null && isStaff();
      allow read: if request.auth != null && (isStaff() || isAdmin());
    }

    // Restock requests: staff can create, admin can read all
    match /restock_requests/{reqId} {
      allow create: if request.auth != null && (isStaff() || isAdmin());
      allow read: if request.auth != null && isAdmin();
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isStaff() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }
  }
}
